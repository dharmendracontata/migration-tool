# ─── OPENSEARCH DESTINATION (local Docker) ────────────────────────────────────
# The index where migrated patent documents are written.
OPENSEARCH_ENDPOINT=https://localhost:9200
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=admin
OPENSEARCH_INDEX=patent-matters

# ─── MYSQL SOURCE (AWS RDS — read-only, data being migrated) ──────────────────
# Points at the staging/production RDS instance that holds the source data.
# Only SELECT queries are ever issued against this connection.
MYSQL_HOST=your-rds-host.rds.amazonaws.com
MYSQL_PORT=3306
MYSQL_USER=your_rds_username
MYSQL_PASSWORD=your_rds_password
MYSQL_DATABASE=matters_db

# ─── MYSQL LOG DESTINATION (local Docker) ─────────────────────────────────────
# Separate local MySQL used ONLY to persist the migration_logs table.
# Must NOT be the same as MYSQL_HOST above — the source RDS is read-only.
MYSQL_LOG_HOST=127.0.0.1
MYSQL_LOG_PORT=3306
MYSQL_LOG_USER=root
MYSQL_LOG_PASSWORD=mysql
MYSQL_LOG_DATABASE=matters_db

# ─── MIGRATION TUNING ─────────────────────────────────────────────────────────
BATCH_SIZE=1000
PARALLEL_WORKERS=4
OPENSEARCH_BULK_MB=45
MAX_RETRIES=5
SLEEP_ON_429_MS=10000
LOG_BATCH_SIZE=500
NODE_ENV=prod           # Set to "prod" to enable migration_logs MySQL writes

# ─── SENTRY ERROR LOGGING ─────────────────────────────────────────────────────
# Sentry DSN for error reporting
SENTRY_DSN=

